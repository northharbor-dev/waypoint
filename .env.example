# Waypoint Configuration
# Copy to .env and fill in your values.

# MongoDB connection string (required)
WAYPOINT_MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name (default: waypoint)
WAYPOINT_MONGO_DATABASE=waypoint

# Project scope -- all commands operate within this project (required)
WAYPOINT_PROJECT=my-project

# Cloud PNG renderer URL (only used with --renderer cloud)
# Default: https://mermaid.ink
WAYPOINT_RENDER_URL=https://mermaid.ink
